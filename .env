# Lamazi Client App — Environment Variables
# Copy to .env.local and fill in values

# Backend API URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Google Maps API Key (for MapDiscovery page)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyBtAi5d55wbgWKYBAuYl8LEpIxQJDdN3BQ

# Firebase (for document uploads via therapist portal)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
